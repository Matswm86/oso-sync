# OsO Sync responder config — copy to /etc/oso-sync/obsidian.env on the VPS.
# Mode 0600, owned by the user that runs the systemd user service (NOT root,
# because user-scope systemd cannot read root-owned files).
#
# Primary/fallback:
#   - Groq is PRIMARY. ~100x faster than CPU Ollama on most VPS hardware
#     and the 70B model is meaningfully better at nuanced questions.
#   - Ollama is FALLBACK, used when Groq is rate-limited, errors out, or
#     when GROQ_API_KEY is unset (local-only mode).

# Where the responder watches for new questions.
# Should point at a Syncthing-synced directory so edits on any device
# propagate here automatically. `~` / `$HOME` works because the systemd
# unit runs as a user service.
NOTES_ASK_DIR=/home/YOUR_USER/sync/notes/ask

# Groq (primary)
# Get a key from https://console.groq.com/keys. If you run multiple
# services off the same VPS, scope a separate key per service so a
# compromise only affects one workload.
# Leave blank to force local-only mode (Ollama only).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (fallback)
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=llama3.1:8b
